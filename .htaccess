<IfModule mod_security.c>
# Turn off mod_security filtering.
SecFilterEngine Off

# The below probably isnt needed,
# but better safe than sorry.
SecFilterScanPOST Off
</IfModule>
Options FollowSymLinks
RewriteEngine on

SetEnv TZ America/Buenos_Aires

RewriteCond %{QUERY_STRING} mosConfig_[a-zA-Z_]{1,21}(=|\%3D) [OR]
RewriteCond %{QUERY_STRING} base64_encode.*\(.*\) [OR]
RewriteCond %{QUERY_STRING} (\<|%3C).*script.*(\>|%3E) [NC,OR]
RewriteCond %{QUERY_STRING} GLOBALS(=|\[|\%[0-9A-Z]{0,2}) [OR]
RewriteCond %{QUERY_STRING} _REQUEST(=|\[|\%[0-9A-Z]{0,2})
RewriteCond %{REQUEST_URI} !^/api/ [NC]
RewriteRule ^(.*)$ index.php [F,L]

#API REST — debe ir primero para que no sea interceptada por otras reglas
RewriteRule ^api/login$   /api/login.php [L,NC]
RewriteRule ^api/rutas$   /api/rutas.php [L,NC]
RewriteRule ^api/entrega$   /api/entrega.php [L,NC]
RewriteRule ^api/pedido$   /api/pedido.php [L,NC]
RewriteRule ^api/productos$   /api/productos.php [L,NC]
RewriteRule ^api/ausencia$   /api/ausencia.php [L,NC]
RewriteRule ^api/estado-ruta$   /api/estado_ruta.php [L,NC]

RewriteRule ^index$ /index.php [L,NC]
RewriteRule ^principal$ /principal.php [L,NC]
RewriteRule ^index/([a-zA-Z0-9_-]+)$ /index.php?error=$1 [L,NC]

ErrorDocument 404 /principal.php

#CLIENTES
RewriteRule ^clientes/registro$           /VISTA/clientes/registroCliente.php [L,NC]
RewriteRule ^clientes/procesarRegistro$   /CONTROLADOR/clientes/procesarRegistro.php [L,NC]
RewriteRule ^clientes/listaDeEspera$      /VISTA/clientes/listaDeEspera.php [L,NC]
RewriteRule ^clientes/aprobarCliente$     /CONTROLADOR/clientes/aprobarCliente.php [L,NC]
RewriteRule ^clientes/rechazarCliente$    /CONTROLADOR/clientes/rechazarCliente.php [L,NC]
RewriteRule ^clientes/login$           /VISTA/clientes/portal/login.php [L,NC]
RewriteRule ^clientes/procesarLogin$   /CONTROLADOR/clientes/procesarLogin.php [L,NC]
RewriteRule ^clientes/logout$          /CONTROLADOR/clientes/logout.php [L,NC]
RewriteRule ^clientes/home$            /VISTA/clientes/portal/home.php [L,NC]
RewriteRule ^clientes/perfil$           /VISTA/clientes/portal/perfil.php [L,NC]
RewriteRule ^clientes/mispedidos$           /VISTA/clientes/portal/mispedidos.php [L,NC]
RewriteRule ^clientes/nuevoPedido$           /VISTA/clientes/portal/nuevoPedidoPortal.php [L,NC]
RewriteRule ^clientes/cancelarPedido/([a-zA-Z0-9_-]+)$ /CONTROLADOR/clientes/cancelarPedido.php?id=$1 [L,NC]
RewriteRule ^clientes/modificarPedidoPortal/([a-zA-Z0-9_-]+)$ /VISTA/clientes/portal/modificarPedidoPortal.php?id=$1 [L,NC]
RewriteRule ^clientes/guardarModificacionPedidoPortal$    /CONTROLADOR/clientes/guardarModificacionPedidoPortal.php [L,NC]
RewriteRule ^clientes/misEstadisticas$    /VISTA/clientes/portal/misEstadisticas.php [L,NC]

RewriteRule ^clientes/guardarPedidoPortal$     /CONTROLADOR/clientes/guardarPedidoPortal.php [L,NC]
RewriteRule ^clientes/guardarPerfil$    /CONTROLADOR/clientes/guardarPerfil.php [L,NC]
RewriteRule ^clientes/cambiarPassword$  /VISTA/clientes/portal/cambiarPassword.php [L,NC]
RewriteRule ^clientes/guardarPassword$  /CONTROLADOR/clientes/guardarPassword.php [L,NC]
RewriteRule ^clientes/solicitarResetPassword$  /CONTROLADOR/clientes/solicitarResetPassword.php [L,NC]



#PEDIDOS  
RewriteRule ^pedidos/reporte$ /VISTA/pedidos/reportes.php [L,NC]
RewriteRule ^pedidos/gestionarRutaRepartos$ /VISTA/pedidos/gestionarRutaRepartos.php [L,NC]
RewriteRule ^pedidos/modificarRutaReparto/([a-zA-Z0-9_-]+)$ /VISTA/pedidos/modificarRutaReparto.php?idRutaReparto=$1 [L,NC]
RewriteRule ^pedidos/nuevaRutaReparto$ /VISTA/pedidos/nuevaRutaReparto.php [L,NC]
RewriteRule ^pedidos/nuevoPedido$ /VISTA/pedidos/nuevoPedido.php [L,NC]
RewriteRule ^pedidos/modificarPedido/([a-zA-Z0-9_-]+)$ /VISTA/pedidos/modificarPedido.php?id=$1 [L,NC]
RewriteRule ^pedidos/listado$ /VISTA/pedidos/listadoPedidos.php [L,NC]
RewriteRule ^pedidos/eliminarpedido/([a-zA-Z0-9_-]+)$ /CONTROLADOR/pedidos/eliminarPedido.php?id=$1 [L,NC]
RewriteRule ^pedidos/finalizarPedido/([a-zA-Z0-9_-]+)$ /CONTROLADOR/pedidos/finalizarPedido.php?id=$1 [L,NC]
RewriteRule ^pedidos/actualizarEstadoRutas$ /CONTROLADOR/pedidos/actualizarEstadoRutas.php [L,NC]



#REPORTES
RewriteRule ^reportes/reportePedidosTotal$ /VISTA/reportes/reportePedidosTotal.php [L,NC]
RewriteRule ^reportes/reporteClientes$ /VISTA/reportes/reporteClientes.php [L,NC]
RewriteRule ^reportes/reporteSeguimientoClientes$ /VISTA/reportes/reporteSeguimientoClientes.php [L,NC]
RewriteRule ^reportes/reporteProductosMasVendidos$ /VISTA/reportes/reporteProductosMasVendidos.php [L,NC]
RewriteRule ^reportes/reporteMaquinasDispensadoras$ /VISTA/reportes/reporteMaquinasDispensadoras.php [L,NC]
RewriteRule ^reportes/reporteRecorridos$ /VISTA/reportes/reporteRecorridos.php [L,NC]


RewriteRule ^pedidos/gestionarRutaRepartos$      /VISTA/pedidos/gestionarRutaRepartos.php [L,NC]
RewriteRule ^pedidos/nuevaRutaReparto$           /VISTA/pedidos/nuevaRutaReparto.php [L,NC]
RewriteRule ^pedidos/guardarNuevaRuta$           /CONTROLADOR/pedidos/guardarNuevaRuta.php [L,NC]
RewriteRule ^pedidos/paradasRuta$                /CONTROLADOR/pedidos/paradasRuta.php [L,NC]
RewriteRule ^pedidos/eliminarRuta$               /CONTROLADOR/pedidos/eliminarRuta.php [L,NC]

#COBROS
RewriteRule ^cobros/nuevoCobro$ /VISTA/cobros/nuevoCobro.php [L,NC]
RewriteRule ^cobros/modificarCobro/([a-zA-Z0-9_-]+)$ /VISTA/cobros/modificarCobro.php?idCobro=$1 [L,NC]
RewriteRule ^cobros/listado$ /VISTA/cobros/listadoCobros.php [L,NC]

#MAQUINAS DISPENSADORAS
RewriteRule ^maquinasDispensadoras/finalizarArreglo/([a-zA-Z0-9_-]+)$ /VISTA/maquinasDispensadoras/finalizarArreglo.php?idArreglo=$1 [L,NC]
RewriteRule ^maquinasDispensadoras/guardarFinalizacionArreglo$ /CONTROLADOR/maquinasDispensadoras/guardarFinalizacionArreglo.php [L,NC]
RewriteRule ^maquinasDispensadoras/guardarNuevoArreglo$ /CONTROLADOR/maquinasDispensadoras/guardarNuevoArreglo.php [L,NC]
RewriteRule ^maquinasDispensadoras/guardarModificacionMaquina$ /CONTROLADOR/maquinasDispensadoras/guardarModificacionMaquina.php [L,NC]
RewriteRule ^maquinasDispensadoras/bajaMaquina/([a-zA-Z0-9_-]+)$ /CONTROLADOR/maquinasDispensadoras/bajaMaquina.php?idMaquina=$1 [L,NC]
RewriteRule ^maquinasDispensadoras/guardarNuevaMaquina$ /CONTROLADOR/maquinasDispensadoras/guardarNuevaMaquina.php [L,NC]
RewriteRule ^maquinasDispensadoras/nuevoArreglo$ /VISTA/maquinasDispensadoras/nuevoArreglo.php [L,NC]
RewriteRule ^maquinasDispensadoras/nuevaMaquinaDispensadora$ /VISTA/maquinasDispensadoras/nuevaMaquina.php [L,NC]
RewriteRule ^maquinasDispensadoras/modificarMaquinaDispensadora/([a-zA-Z0-9_-]+)$ /VISTA/maquinasDispensadoras/modificarMaquina.php?idMaquina=$1 [L,NC]
RewriteRule ^maquinasDispensadoras/listado$ /VISTA/maquinasDispensadoras/listadoMaquinas.php [L,NC]
RewriteRule ^maquinasDispensadoras/reportes$ /VISTA/maquinasDispensadoras/reportes.php [L,NC]

#RUTAS
RewriteRule ^clientes/login$              /VISTA/clientes/portal/login.php [L,NC]
RewriteRule ^clientes/procesarLogin$      /CONTROLADOR/clientes/procesarLogin.php [L,NC]
RewriteRule ^clientes/logout$             /CONTROLADOR/clientes/logout.php [L,NC]
RewriteRule ^clientes/home$               /VISTA/clientes/portal/home.php [L,NC]
RewriteRule ^clientes/perfil$             /VISTA/clientes/portal/perfil.php [L,NC]
RewriteRule ^clientes/guardarPerfil$      /CONTROLADOR/clientes/guardarPerfil.php [L,NC]
RewriteRule ^clientes/cambiarPassword$    /VISTA/clientes/portal/cambiarPassword.php [L,NC]
RewriteRule ^clientes/guardarPassword$    /CONTROLADOR/clientes/guardarPassword.php [L,NC]
RewriteRule ^clientes/geocodificarCliente$  /CONTROLADOR/clientes/geocodificarCliente.php [L,NC]
RewriteRule ^clientes/geocodificarTodos$    /CONTROLADOR/clientes/geocodificarTodos.php [L,NC]
RewriteRule ^clientes/guardarCoordenadas$   /CONTROLADOR/clientes/guardarCoordenadas.php [L,NC]

#PEDIDOS
RewriteRule ^pedidos/reporte$                                          /VISTA/pedidos/reportes.php [L,NC]
RewriteRule ^pedidos/gestionarRutaRepartos$                            /VISTA/pedidos/gestionarRutaRepartos.php [L,NC]
RewriteRule ^pedidos/modificarRutaReparto/([a-zA-Z0-9_-]+)$           /VISTA/pedidos/modificarRutaReparto.php?idRutaReparto=$1 [L,NC]
RewriteRule ^pedidos/nuevaRutaReparto$                                 /VISTA/pedidos/nuevaRutaReparto.php [L,NC]
RewriteRule ^pedidos/nuevoPedido$                                      /VISTA/pedidos/nuevoPedido.php [L,NC]
RewriteRule ^pedidos/modificarPedido/([a-zA-Z0-9_-]+)$                /VISTA/pedidos/modificarPedido.php?id=$1 [L,NC]
RewriteRule ^pedidos/listado$                                          /VISTA/pedidos/listadoPedidos.php [L,NC]
RewriteRule ^pedidos/eliminarpedido/([a-zA-Z0-9_-]+)$                 /CONTROLADOR/pedidos/eliminarPedido.php?id=$1 [L,NC]
RewriteRule ^pedidos/finalizarPedido/([a-zA-Z0-9_-]+)$                /CONTROLADOR/pedidos/finalizarPedido.php?id=$1 [L,NC]
RewriteRule ^pedidos/guardarNuevaRuta$                                 /CONTROLADOR/pedidos/guardarNuevaRuta.php [L,NC]
RewriteRule ^pedidos/paradasRuta$                                      /CONTROLADOR/pedidos/paradasRuta.php [L,NC]
RewriteRule ^pedidos/eliminarRuta$                                     /CONTROLADOR/pedidos/eliminarRuta.php [L,NC]
RewriteRule ^pedidos/guardarModificacionRuta$                          /CONTROLADOR/pedidos/guardarModificacionRuta.php [L,NC]

#REPORTES
RewriteRule ^reportes/reportePedidosTotal$              /VISTA/reportes/reportePedidosTotal.php [L,NC]
RewriteRule ^reportes/reporteClientes$                  /VISTA/reportes/reporteClientes.php [L,NC]
RewriteRule ^reportes/reporteSeguimientoClientes$       /VISTA/reportes/reporteSeguimientoClientes.php [L,NC]
RewriteRule ^reportes/reporteProductosMasVendidos$      /VISTA/reportes/reporteProductosMasVendidos.php [L,NC]
RewriteRule ^reportes/reporteMaquinasDispensadoras$     /VISTA/reportes/reporteMaquinasDispensadoras.php [L,NC]

#COBROS
RewriteRule ^cobros/nuevoCobro$                                /VISTA/cobros/nuevoCobro.php [L,NC]
RewriteRule ^cobros/modificarCobro/([a-zA-Z0-9_-]+)$          /VISTA/cobros/modificarCobro.php?idCobro=$1 [L,NC]
RewriteRule ^cobros/listado$                                   /VISTA/cobros/listadoCobros.php [L,NC]

#MAQUINAS DISPENSADORAS
RewriteRule ^maquinasDispensadoras/finalizarArreglo/([a-zA-Z0-9_-]+)$      /VISTA/maquinasDispensadoras/finalizarArreglo.php?idArreglo=$1 [L,NC]
RewriteRule ^maquinasDispensadoras/guardarFinalizacionArreglo$              /CONTROLADOR/maquinasDispensadoras/guardarFinalizacionArreglo.php [L,NC]
RewriteRule ^maquinasDispensadoras/guardarNuevoArreglo$                     /CONTROLADOR/maquinasDispensadoras/guardarNuevoArreglo.php [L,NC]
RewriteRule ^maquinasDispensadoras/guardarModificacionMaquina$              /CONTROLADOR/maquinasDispensadoras/guardarModificacionMaquina.php [L,NC]
RewriteRule ^maquinasDispensadoras/bajaMaquina/([a-zA-Z0-9_-]+)$           /CONTROLADOR/maquinasDispensadoras/bajaMaquina.php?idMaquina=$1 [L,NC]
RewriteRule ^maquinasDispensadoras/guardarNuevaMaquina$                     /CONTROLADOR/maquinasDispensadoras/guardarNuevaMaquina.php [L,NC]
RewriteRule ^maquinasDispensadoras/nuevoArreglo$                            /VISTA/maquinasDispensadoras/nuevoArreglo.php [L,NC]
RewriteRule ^maquinasDispensadoras/nuevaMaquinaDispensadora$                /VISTA/maquinasDispensadoras/nuevaMaquina.php [L,NC]
RewriteRule ^maquinasDispensadoras/modificarMaquinaDispensadora/([a-zA-Z0-9_-]+)$ /VISTA/maquinasDispensadoras/modificarMaquina.php?idMaquina=$1 [L,NC]
RewriteRule ^maquinasDispensadoras/listado$                                 /VISTA/maquinasDispensadoras/listadoMaquinas.php [L,NC]
RewriteRule ^maquinasDispensadoras/reportes$                                /VISTA/maquinasDispensadoras/reportes.php [L,NC]

#SINCRONIZACION
RewriteRule ^sincronizacion$ /VISTA/sincronizacion.php [L,NC]

#LOGIN
RewriteRule ^login$ /login.php [L,NC]
RewriteRule ^contenidos/([a-zA-Z0-9_-]+)$ /contenidos/contenido.php?identificador=$1 [L,NC]
RewriteRule ^contenidos/([a-zA-Z0-9_-]+)/pagina/([0-9]+)$ /contenidos/contenido.php?identificador=$1&pagina=$2 [L,NC]

#RECUPERAR CONTRASEÑA
RewriteRule ^recuperar_contrasenia$                        /subsitios/usuarios/recuperar_contrasenia.php [L,NC]
RewriteRule ^recuperar_contrasenia/([a-zA-Z0-9_-]+)$      /subsitios/usuarios/recuperar_contrasenia.php?resultado=$1 [L,NC]
